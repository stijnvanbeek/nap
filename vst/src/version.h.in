#pragma once

#include "pluginterfaces/base/fplatform.h"

#define MAJOR_VERSION_STR "@major_version@"
#define MAJOR_VERSION_INT @major_version@

#define SUB_VERSION_STR "@sub_version@"
#define SUB_VERSION_INT @sub_version@

#define RELEASE_NUMBER_STR "@release_number@"
#define RELEASE_NUMBER_INT @release_number@

#define BUILD_NUMBER_STR "@build_numer@" // Build number to be sure that each result could identified.
#define BUILD_NUMBER_INT @build_numer@

// Version with build number (example "1.0.3.342")
#define FULL_VERSION_STR MAJOR_VERSION_STR "." SUB_VERSION_STR "." RELEASE_NUMBER_STR "." BUILD_NUMBER_STR

// Version without build number (example "1.0.3")
#define VERSION_STR MAJOR_VERSION_STR "." SUB_VERSION_STR "." RELEASE_NUMBER_STR

// HERE you have to define your plug-in, company name, email and web
#define stringPluginName		"@project_name@"

#if SMTG_PLATFORM_64
#define stringFileDescription	stringPluginName" VST3-SDK (64Bit)"
#else
#define stringFileDescription	stringPluginName" VST3-SDK"
#endif

#define stringCompanyName		"@company_name@"
#define stringCompanyWeb		"@company_website@"
#define stringCompanyEmail		"@company_email@"